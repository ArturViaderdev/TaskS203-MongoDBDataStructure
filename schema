use("optics");
db.createCollection("client_orders", {
  validator:
  {
    $jsonSchema: {
      title: 'Client',
      bsonType: 'object',
      required: [
        'address',
        'telephone',
        'email',
        'register_date'
      ],
      properties: {
        address: {
          bsonType: 'string',
          description: 'Fieldname1 must be a string'
        },
        telephone: {
          bsonType: 'string',
          description: 'Fieldname1 must be a string'
        },
        email: {
          bsonType: 'string',
          description: 'Fieldname1 must be a string'
        },
        register_date: {
          bsonType: 'date',
          description: 'Fieldname1 must be a date'
        },
        lastshoppings: {
          bsonType: 'array',
          items: {
            title: 'shop',
            bsonType: 'object',
            properties: {
              brand: {
                bsonType: 'string'
              },
              graduationl: {
                bsonType: 'decimal'
              },
              graduationr: {
                bsonType: 'decimal'
              },
              glasscolorl: {
                bsonType: 'string'
              },
              glasscolorr: {
                bsonType: 'string'
              },
              frametype: {
                bsonType: 'string'
              },
              price: {
                bsonType: 'decimal'
              }
            }
          }
        }
      }
    }
  }
})

db.client_orders.insertOne({
    address: "Right Street,123",
    telephone: "678921235",
    email: "email@email.com",
    register_date:new ISODate("2023-09-23"),
    lastshoppings:[{
        brand:"Rayban",
        graduationl:NumberDecimal("1.5"),
        graduationr:NumberDecimal("1.6"),
        glasscolorl:"red",
        glasscolorr:"blue",
        frametype:"metallic",
        price: NumberDecimal("100")
    }],
});


